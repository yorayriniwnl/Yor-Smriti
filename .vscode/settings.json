{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": true
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.alwaysShowStatus": true,
  "files.watcherExclude": {
    "**/.next/**": true,
    "**/node_modules/**": true
  },
  "files.exclude": {
    "**/.next": true
  }
}
