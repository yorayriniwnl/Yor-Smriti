# ─── Yor Smriti — Environment Variables ───────────────────────────────────────
# Copy to .env.local and fill in values. Never commit .env.local to git.
# Generate AUTH_SECRET: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"

# ── Auth ───────────────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-to-a-random-64-char-string-in-production

# ── App credentials ────────────────────────────────────────────────────────────
# Leave BOTH blank → open access (anyone with the link can enter).
# Set BOTH → gate behind a password.
# The login UI only asks for the password; the server applies APP_USERNAME internally.
APP_USERNAME=yorayrin
APP_PASSWORD=changeme

# ── Personalization ────────────────────────────────────────────────────────────
RECIPIENT_NAME=Smriti
SENDER_NAME=Ayrin
RECIPIENT_MEMORY=that rainy chai walk
SENDER_MESSAGE=I am still here, trying to become better.

# ── OpenAI (AI chat) ───────────────────────────────────────────────────────────
# Falls back to curated local replies if unset.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Resend (transactional email) ───────────────────────────────────────────────
# Free tier: 3,000 emails/month · https://resend.com
# Falls back to console logging if unset.
RESEND_API_KEY=re_...

# Email address shown as sender (must be a verified domain in Resend)
SENDER_EMAIL=Yor Smriti <noreply@your-domain.com>

# Where to receive admin notifications (waitlist signups, replies)
NOTIFICATION_EMAIL=your@email.com

# ── Redis (rate limiting) ──────────────────────────────────────────────────────
# Without Redis, rate limits reset on server restart.
# Option A: Upstash (serverless, recommended for Vercel) https://upstash.com
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Option B: Standard Redis (ioredis)
# REDIS_URL=redis://:password@host:6379/0

# ── Rate limiting overrides ────────────────────────────────────────────────────
# LOGIN_RATE_LIMIT=10
# LOGIN_RATE_WINDOW_MS=60000
# CHAT_RATE_LIMIT=20
# CHAT_RATE_WINDOW_MS=60000

# ── Next.js ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
