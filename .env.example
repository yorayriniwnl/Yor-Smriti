# ─── Yor Smriti — Environment Variables ───────────────────────────────────────
# Copy to .env.local and fill in values. Never commit .env.local to git.
# Generate AUTH_SECRET: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"

# ── Auth ───────────────────────────────────────────────────────────────────────
# REQUIRED — JWT signing secret (≥32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=change-me-to-a-random-64-char-string-in-production

# ── App credentials ────────────────────────────────────────────────────────────
# Leave BOTH blank → open access (anyone with the link can enter).
# Set BOTH → gate behind a password.
# The login UI only asks for the password; the server applies APP_USERNAME internally.
APP_USERNAME=yorayrin
APP_PASSWORD=changeme

# ── Personalization ────────────────────────────────────────────────────────────
RECIPIENT_NAME=Smriti
SENDER_NAME=Ayrin
RECIPIENT_MEMORY=that rainy chai walk
SENDER_MESSAGE=I am still here, trying to become better.

# ── AI chat personalization ────────────────────────────────────────────────────
# These fill in the system prompt that shapes Ayrin's voice in /her AI chat.
# All fields are required for the AI to speak authentically — fill them in before
# sharing the experience. Defaults ship with placeholder prose so the app never
# renders raw brackets, but replace them with your real story.
CHAT_RELATIONSHIP_LENGTH=about a year and a half
CHAT_BREAKUP_TIMEFRAME=a few months ago
CHAT_BREAKUP_REASON=I kept pulling away emotionally whenever things got serious. She needed consistency and I gave her uncertainty.
CHAT_WHAT_SHE_MEANS=She is the most honest person I have ever been close to. She always said exactly what she meant, and I never appreciated that until I lost it.
CHAT_MEMORY_1=The night we sat talking until 2am about what we both actually wanted from life.
CHAT_MEMORY_2=The way she laughed at something small and then went quiet, like she was surprised by her own happiness.
CHAT_MEMORY_3=Walking in the rain and neither of us wanting to go inside.
CHAT_MEMORY_4=Her reading quietly beside me, not needing to fill the silence.
CHAT_MEMORY_5=The last time I saw her — I knew it and said nothing.
CHAT_WANT_HER_TO_KNOW_1=That I think about her every day and I am not saying that to pressure her.
CHAT_WANT_HER_TO_KNOW_2=That I have actually tried to understand what I was doing wrong.
CHAT_WANT_HER_TO_KNOW_3=That I respect whatever she decides. This is not to win her back by force — it is to tell the truth I never told her clearly.

# ── /her page portrait paragraphs ─────────────────────────────────────────────
# These are the 8 paragraphs shown on the "Who you are" page (/her).
# Set NEXT_PUBLIC_HER_PARAGRAPH_1 … _8 with your own specific, true observations.
# Defaults are genuine prose — but replace them with what is actually true of her.
NEXT_PUBLIC_HER_PARAGRAPH_1=She notices things before she says them. There is a small delay between seeing and speaking that most people do not have — she uses it to make sure what she says is actually true.
NEXT_PUBLIC_HER_PARAGRAPH_2=When she argues, she goes quiet first. Not to retreat — to load. She does not raise her voice because she does not need to. She has already figured out exactly where you are wrong.
NEXT_PUBLIC_HER_PARAGRAPH_3=Her silence is not one thing. There is the silence of her thinking, the silence of her deciding whether you have earned more of her, and the silence that means she has already left the conversation even if she is still in the room.
NEXT_PUBLIC_HER_PARAGRAPH_4=When she is nervous, she gets very precise. Her sentences get shorter. She asks practical questions about things that do not need answers. It is the only time she talks to fill space.
NEXT_PUBLIC_HER_PARAGRAPH_5=When she trusts someone, she starts finishing sentences she would normally leave half-said. She stops editing herself mid-thought. It is the closest thing she has to completely letting go.
NEXT_PUBLIC_HER_PARAGRAPH_6=She always knows exactly where she put things. Not because she is tidy — because she pays attention to the moment she sets something down. She is present in a way most people are not.
NEXT_PUBLIC_HER_PARAGRAPH_7=She returns to certain ideas the way people return to songs — not to resolve them but because living near them feels necessary. She does not need an audience for this. She would do it alone forever.
NEXT_PUBLIC_HER_PARAGRAPH_8=She is more loyal than she lets on. She holds more than she shows. She is harder on herself than she would ever be on someone she loves. That is the thing about her I understood last and too late.

# ── OpenAI (AI chat) ───────────────────────────────────────────────────────────
# Falls back to curated local replies if unset.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# OpenAI model for chat (default: gpt-4o-mini). Override to use a different model.
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Resend (transactional email) ───────────────────────────────────────────────
# Free tier: 3,000 emails/month · https://resend.com
# Falls back to console logging if unset.
RESEND_API_KEY=re_...

# Email address shown as sender (must be a verified domain in Resend)
SENDER_EMAIL=Yor Smriti <noreply@your-domain.com>

# Where to receive admin notifications (waitlist signups, replies)
NOTIFICATION_EMAIL=your@email.com

# ── Redis (rate limiting) ──────────────────────────────────────────────────────
# Without Redis, rate limits reset on server restart.
# Option A: Upstash (serverless, recommended for Vercel) https://upstash.com
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Option B: Standard Redis (ioredis)
# REDIS_URL=redis://:password@host:6379/0

# ── Rate limiting overrides ────────────────────────────────────────────────────
# LOGIN_RATE_LIMIT=10
# LOGIN_RATE_WINDOW_MS=60000
# CHAT_RATE_LIMIT=20
# CHAT_RATE_WINDOW_MS=60000

# ── Proxy trust (REQUIRED on Vercel for correct rate limiting) ─────────────────
# Without this every request comes from "unknown" and shares one rate-limit bucket.
# Set to "1" when deployed behind Vercel or any trusted reverse proxy.
TRUST_PROXY=1

# ── Protected page password ────────────────────────────────────────────────────
# Password for /for-her-alone. If unset, the page is blocked for everyone.
HER_UNLOCK_PASSWORD=changeme

# ── Prometheus scrape secret ───────────────────────────────────────────────────
# Optional bearer token for /api/metrics. Lets Prometheus scrape without a session.
# Authorization: Bearer <value>
# METRICS_SCRAPE_SECRET=

# ── Logging ────────────────────────────────────────────────────────────────────
# LOG_LEVEL=info           # error | warn | info | debug (default: info in prod, debug in dev)
# LOG_JSON=1               # force JSON output locally (automatically on in production)

# ── Next.js ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Counter date ───────────────────────────────────────────────────────────────
# The "he has been working on this for X days" counter on the root page.
# Format: YYYY-MM-DD. Set to your real start date to avoid a code push.
# NEXT_PUBLIC_SINCE_DATE=2025-05-18
