# Example environment variables for development and production

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Optional: simple app credentials used by /api/login (only if you want a fixed login)
# If not set, /api/login will return 500 (misconfigured) until you configure credentials.
APP_USERNAME=admin
APP_PASSWORD=changeme

# Redis URL (optional). When set, rate-limiter will use Redis for counters.
# Example formats:
#  redis://:password@redis-host:6379/0
#  rediss://:password@redis-host:6380/0  (TLS)
REDIS_URL=

# Rate limiter defaults (optional)
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_MS=60000
CHAT_RATE_LIMIT=20
CHAT_RATE_WINDOW_MS=60000

# Next.js
NEXT_PUBLIC_BASE_URL=http://localhost:3000
